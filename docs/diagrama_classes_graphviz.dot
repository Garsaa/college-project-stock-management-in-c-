digraph DiagramaClassesEstoque {
    graph [
        label="Diagrama de Classes - Modulo de Estoque",
        labelloc=t,
        fontsize=22,
        fontname="Arial",
        rankdir=LR,
        splines=spline,
        nodesep=0.65,
        ranksep=1.0,
        bgcolor="white",
        pad=0.35
    ];

    node [
        shape=plain,
        fontname="Arial"
    ];

    edge [
        fontname="Arial",
        fontsize=10,
        color="#37474F",
        arrowsize=0.8
    ];

    MovimentoEstoque [
        label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#2E7D32">
            <TR><TD BGCOLOR="#DFF3E3"><FONT POINT-SIZE="10">&lt;&lt;struct&gt;&gt;</FONT><BR/><FONT POINT-SIZE="16"><B>MovimentoEstoque</B></FONT></TD></TR>
            <TR><TD ALIGN="LEFT">+ operacao: string</TD></TR>
            <TR><TD ALIGN="LEFT">+ quantidade: int</TD></TR>
            <TR><TD ALIGN="LEFT">+ observacao: string</TD></TR>
        </TABLE>>
    ];

    ItemEstoque [
        label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#1565C0">
            <TR><TD BGCOLOR="#DCEBFF"><FONT POINT-SIZE="10">&lt;&lt;abstract&gt;&gt;</FONT><BR/><FONT POINT-SIZE="16"><B>ItemEstoque</B></FONT></TD></TR>
            <TR><TD ALIGN="LEFT">- codigo_: string</TD></TR>
            <TR><TD ALIGN="LEFT">- tipoItem_: string</TD></TR>
            <TR><TD ALIGN="LEFT">- nome_: string</TD></TR>
            <TR><TD ALIGN="LEFT">- descricao_: string</TD></TR>
            <TR><TD ALIGN="LEFT">- linkInformacoes_: string</TD></TR>
            <TR><TD ALIGN="LEFT">- quantidade_: int</TD></TR>
            <TR><TD ALIGN="LEFT">- precoUnitario_: double</TD></TR>
            <TR><TD ALIGN="LEFT">- localizacao_: string</TD></TR>
            <TR><TD ALIGN="LEFT">- movimentos_: vector&lt;MovimentoEstoque&gt;</TD></TR>
            <TR><TD BORDER="1" COLOR="#90A4AE"></TD></TR>
            <TR><TD ALIGN="LEFT">+ valorTotal(): double</TD></TR>
            <TR><TD ALIGN="LEFT">+ alvoBuscaInternet(): string</TD></TR>
            <TR><TD ALIGN="LEFT">+ registrarEntrada(qtd, obs): void</TD></TR>
            <TR><TD ALIGN="LEFT">+ registrarSaida(qtd, obs): void</TD></TR>
            <TR><TD ALIGN="LEFT">+ adicionarRegistroMovimento(op, qtd, obs): void</TD></TR>
            <TR><TD ALIGN="LEFT"><I>+ tipo(): string</I></TD></TR>
            <TR><TD ALIGN="LEFT"><I>+ imprimirResumo(out): void</I></TD></TR>
            <TR><TD ALIGN="LEFT"><I>+ imprimirDetalhado(out): void</I></TD></TR>
            <TR><TD ALIGN="LEFT"># validarCamposComuns(): void</TD></TR>
        </TABLE>>
    ];

    Produto [
        label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#6A1B9A">
            <TR><TD BGCOLOR="#F0E3FF"><FONT POINT-SIZE="10">&lt;&lt;class&gt;&gt;</FONT><BR/><FONT POINT-SIZE="16"><B>Produto</B></FONT></TD></TR>
            <TR><TD ALIGN="LEFT">+ Produto(codigo, tipo, nome, descricao, link, qtd, preco, localizacao)</TD></TR>
            <TR><TD ALIGN="LEFT">+ tipo(): string</TD></TR>
            <TR><TD ALIGN="LEFT">+ imprimirResumo(out): void</TD></TR>
            <TR><TD ALIGN="LEFT">+ imprimirDetalhado(out): void</TD></TR>
        </TABLE>>
    ];

    Estoque [
        label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#455A64">
            <TR><TD BGCOLOR="#ECEFF1"><FONT POINT-SIZE="10">&lt;&lt;class&gt;&gt;</FONT><BR/><FONT POINT-SIZE="16"><B>Estoque</B></FONT></TD></TR>
            <TR><TD ALIGN="LEFT">- itens_: vector&lt;unique_ptr&lt;ItemEstoque&gt;&gt;</TD></TR>
            <TR><TD BORDER="1" COLOR="#90A4AE"></TD></TR>
            <TR><TD ALIGN="LEFT">+ adicionar(item): bool</TD></TR>
            <TR><TD ALIGN="LEFT">+ removerPorCodigo(codigo): bool</TD></TR>
            <TR><TD ALIGN="LEFT">+ localizarPorCodigo(codigo): ItemEstoque*</TD></TR>
            <TR><TD ALIGN="LEFT">+ localizarPorNome(termo): vector&lt;ItemEstoque*&gt;</TD></TR>
            <TR><TD ALIGN="LEFT">+ itens(): const vector&lt;unique_ptr&lt;ItemEstoque&gt;&gt;&amp;</TD></TR>
            <TR><TD ALIGN="LEFT">+ vazio(): bool</TD></TR>
            <TR><TD ALIGN="LEFT">+ limpar(): void</TD></TR>
        </TABLE>>
    ];

    PersistenciaArquivo [
        label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#EF6C00">
            <TR><TD BGCOLOR="#FFF0D9"><FONT POINT-SIZE="10">&lt;&lt;class&gt;&gt;</FONT><BR/><FONT POINT-SIZE="16"><B>PersistenciaArquivo</B></FONT></TD></TR>
            <TR><TD ALIGN="LEFT">- caminhoArquivo_: string</TD></TR>
            <TR><TD BORDER="1" COLOR="#90A4AE"></TD></TR>
            <TR><TD ALIGN="LEFT">+ salvar(estoque): void</TD></TR>
            <TR><TD ALIGN="LEFT">+ carregar(estoque): bool</TD></TR>
            <TR><TD ALIGN="LEFT">+ caminhoArquivo(): const string&amp;</TD></TR>
            <TR><TD ALIGN="LEFT">- criarItem(campos): unique_ptr&lt;ItemEstoque&gt;</TD></TR>
        </TABLE>>
    ];

    Console [
        label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#AD1457">
            <TR><TD BGCOLOR="#FFE1EF"><FONT POINT-SIZE="10">&lt;&lt;namespace&gt;&gt;</FONT><BR/><FONT POINT-SIZE="16"><B>console</B></FONT></TD></TR>
            <TR><TD ALIGN="LEFT">+ lerLinha(...)</TD></TR>
            <TR><TD ALIGN="LEFT">+ lerInteiro(...)</TD></TR>
            <TR><TD ALIGN="LEFT">+ lerDouble(...)</TD></TR>
            <TR><TD ALIGN="LEFT">+ lerSimNao(...)</TD></TR>
            <TR><TD ALIGN="LEFT">+ paraMinusculo(...)</TD></TR>
            <TR><TD ALIGN="LEFT">+ formatarMoeda(...)</TD></TR>
        </TABLE>>
    ];

    Produto -> ItemEstoque [
        arrowhead=empty,
        label="heranca",
        color="#1565C0"
    ];

    ItemEstoque -> MovimentoEstoque [
        arrowtail=diamond,
        dir=both,
        label="0..* movimentos",
        color="#2E7D32"
    ];

    Estoque -> ItemEstoque [
        arrowtail=diamond,
        dir=both,
        label="0..* itens",
        color="#455A64"
    ];

    PersistenciaArquivo -> Estoque [
        style=dashed,
        label="salva / carrega",
        color="#EF6C00"
    ];

    PersistenciaArquivo -> Produto [
        style=dashed,
        label="cria",
        color="#EF6C00"
    ];

    Produto -> Console [
        style=dotted,
        label="formatacao",
        color="#AD1457"
    ];

    { rank=same; Produto; Estoque; PersistenciaArquivo; }
    { rank=same; MovimentoEstoque; Console; }
}
